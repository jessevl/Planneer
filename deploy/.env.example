# Planneer — Production Environment
# Copy to .env and fill in values

# Docker image version (default: latest)
# VERSION=latest

# Port to expose (default: 8090)
# PORT=8090

# PocketBase admin credentials (created on first run)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme-use-a-strong-password

# Registration mode (true = invite-only, false = open registration)
PLANNEER_CLOSED_BETA=false

# Allow PocketBase admin UI in production (default: false)
# PLANNEER_ALLOW_ADMIN_UI=false

# Unsplash API key for cover images (optional)
# UNSPLASH_ACCESS_KEY=
