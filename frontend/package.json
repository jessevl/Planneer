{
  "name": "@planneer/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./api": "./src/api/index.ts",
    "./api/*": "./src/api/*.ts",
    "./stores": "./src/stores/index.ts",
    "./stores/*": "./src/stores/*.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/*": "./src/lib/*.ts",
    "./hooks": "./src/hooks/index.ts",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "hooks:install": "git config --local core.hooksPath .githooks && git config --local push.recurseSubmodules check && chmod +x .githooks/pre-push",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "frameer:publish": "bash ./scripts/publish-frameer.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots": "playwright test e2e/screenshots.spec.ts --project=chromium --reporter=list",
    "icons": "node scripts/generate-icons.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@fontsource-variable/geist": "^5.0.0",
    "@fontsource-variable/geist-mono": "^5.0.0",
    "@frameer/ui": "file:./frameer",
    "@huggingface/transformers": "^3.8.1",
    "@tanstack/react-router": "^1.95.0",
    "@yoopta/blockquote": "6.0.3",
    "@yoopta/callout": "6.0.3",
    "@yoopta/divider": "6.0.3",
    "@yoopta/editor": "6.0.3",
    "@yoopta/headings": "6.0.3",
    "@yoopta/link": "6.0.3",
    "@yoopta/lists": "6.0.3",
    "@yoopta/marks": "6.0.3",
    "@yoopta/paragraph": "6.0.3",
    "@yoopta/tabs": "6.0.3",
    "@yoopta/ui": "6.0.3",
    "dayjs": "^1.11.13",
    "dexie": "^4.2.1",
    "lucide-react": "^0.555.0",
    "pdfjs-dist": "^5.6.205",
    "perfect-freehand": "^1.2.3",
    "pocketbase": "^0.26.3",
    "re-resizable": "^6.11.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "slate": "^0.123.0",
    "slate-dom": "^0.123.0",
    "slate-react": "^0.123.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.11",
    "@tanstack/react-router-devtools": "^1.95.0",
    "@tanstack/router-vite-plugin": "^1.95.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.15",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "jsdom": "^27.4.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.29",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.11",
    "typescript": "^5",
    "typescript-eslint": "^8.53.1",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "lucide-react": "$lucide-react"
  }
}
