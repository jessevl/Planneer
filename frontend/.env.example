# Backend API URL (PocketBase)
# Not needed for development (Vite proxy handles it) or production (same-origin).
# Only set this if your backend is on a different host.
# VITE_POCKETBASE_URL=http://localhost:8090

# E2E Test Credentials (optional)
# These should match PLANNEER_DEMO_PASSWORD in the backend
E2E_TEST_EMAIL=demo@planneer.app
E2E_TEST_PASSWORD=PlanneerDemo2024!Dev
