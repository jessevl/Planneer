# ===================
# Planneer Monorepo
# ===================

# OS
.DS_Store
*.pem
Thumbs.db

# ── Backend ──
# PocketBase data (SQLite database, uploaded files)
backend/pb_data/
# Compiled Go binary
backend/planneer
# Backups
backups/

# ── Frontend ──
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/coverage/
frontend/playwright-report/
frontend/playwright/.cache/
frontend/test-results/
frontend/e2e-results/
frontend/.tanstack/
npm-debug.log*
*.tsbuildinfo

# Env files (keep examples)
.env
.env.*
!.env.example
!deploy/.env.example
!frontend/.env.example

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Docker
.docker/

# Local package manager cache
.npm-cache/
